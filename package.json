{
  "name": "drift-ai",
  "version": "1.1.4",
  "description": "Drift AI — Customer Relationship Management",
  "author": "Drift AI",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "postinstall": "cp node_modules/pdfjs-dist/build/pdf.worker.min.mjs public/pdf.worker.min.mjs || true",
    "dev": "next dev",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "check:llm": "tsx scripts/check-llm-imports.ts",
    "check:schema": "tsx scripts/check-schema.ts",
    "smoke": "tsx tests/smoke/run.ts",
    "evals": "tsx evals/runner.ts",
    "eval:call-summary": "npx tsx evals/call-summary/runner.ts",
    "electron": "electron .",
    "electron:dev": "NODE_ENV=development electron .",
    "electron:debug": "DEBUG=true electron .",
    "electron:build": "electron-builder --publish=never",
    "electron:build:mac": "electron-builder --mac --publish=never",
    "electron:build:win": "electron-builder --win --publish=never",
    "electron:build:linux": "electron-builder --linux --publish=never"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.3",
    "@react-email/components": "^0.5.5",
    "@sentry/nextjs": "^10.48.0",
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.57.4",
    "@tanstack/react-query": "^5.100.8",
    "@xyflow/react": "^12.10.2",
    "alawmulaw": "^6.0.0",
    "chokidar": "^3.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.18",
    "electron-updater": "^6.8.3",
    "form-data": "^4.0.5",
    "framer-motion": "^12.38.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^2.5.2",
    "jszip": "^3.10.1",
    "lucide-react": "^0.544.0",
    "next": "^15.5.4",
    "openai": "^5.22.0",
    "pdf-parse": "^2.4.5",
    "react": "19.1.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.1.0",
    "react-pdf": "^10.3.0",
    "recharts": "^2.12.7",
    "resend": "^6.1.1",
    "stripe": "^20.4.0",
    "tailwind-merge": "^3.3.1",
    "three": "^0.183.2",
    "twilio": "^5.10.2",
    "unpdf": "^1.6.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/form-data": "^2.2.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/twilio": "^3.19.2",
    "@typescript-eslint/eslint-plugin": "^8.44.1",
    "@typescript-eslint/parser": "^8.44.1",
    "autoprefixer": "^10.4.21",
    "electron": "^31.7.7",
    "electron-builder": "^25.1.8",
    "eslint": "^9.36.0",
    "eslint-config-next": "^15.5.5",
    "pg": "^8.18.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "tw-animate-css": "^1.3.8",
    "typescript": "^5",
    "typescript-eslint": "^8.44.1"
  },
  "build": {
    "appId": "com.drift.ai",
    "productName": "Drift AI",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      "public/brand/**/*",
      "package.json"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "MelinaSimp",
        "repo": "drift-crm",
        "releaseType": "release"
      }
    ],
    "mac": {
      "category": "public.app-category.business",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "public/brand/Drift.icns",
      "darkModeSupport": true,
      "artifactName": "Drift-AI-mac-${arch}.${ext}"
    },
    "win": {
      "target": "nsis",
      "icon": "public/brand/Drift.ico",
      "artifactName": "Drift-AI-Setup.${ext}"
    },
    "linux": {
      "target": "AppImage",
      "icon": "public/brand/Drift.icns"
    }
  }
}
