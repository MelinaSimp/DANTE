{
  "version": 2,
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "regions": ["iad1"],
  "crons": [
    {
      "path": "/api/scheduled-sms/process",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/scheduled-emails/process",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/autonomous-agents/cron",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/dante/cron/tick",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/dante/queue/tick",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/dante/cron/digest",
      "schedule": "0 13 * * 1"
    },
    {
      "path": "/api/integrations/gmail/sync",
      "schedule": "0 */4 * * *"
    },
    {
      "path": "/api/integrations/calendar/sync",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/integrations/outlook/sync",
      "schedule": "0 */4 * * *"
    },
    {
      "path": "/api/integrations/microsoft-calendar/sync",
      "schedule": "0 */6 * * *"
    }
  ]
}








